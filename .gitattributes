# Auto detect text files and perform LF normalization
* text=auto

# Enforce LF for source/text files (clean diffs on Windows)
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.svg  text eol=lf

# Treat common assets as binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
